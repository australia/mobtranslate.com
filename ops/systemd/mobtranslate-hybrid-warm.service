[Unit]
Description=MobTranslate - verify and warm enabled Hugging Face adapters
Documentation=https://huggingface.co/spaces/ajaxdavis/alpha-v0-historic
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ajax
ExecStart=/usr/local/bin/mobtranslate-hybrid-warm.sh
TimeoutStartSec=600
Nice=19
CPUSchedulingPolicy=idle
IOSchedulingClass=idle
MemoryMax=256M
